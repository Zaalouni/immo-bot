    <div class="explorer-container">

        <!-- Filters Sidebar -->
        <aside class="filters-sidebar" id="filtersSidebar">
            <h2 class="filters-title">Filtres</h2>

            <!-- PRIX (MAIN FILTERS - TOP) -->
            <div class="filter-group">
                <div class="filter-group-title">
                    <span class="icon">💶</span>
                    <span>Prix (€)</span>
                </div>
                <div class="slider-group">
                    <div class="slider-wrapper">
                        <input type="range" id="priceMin" min="500" max="3500" value="500">
                        <input type="range" id="priceMax" min="500" max="3500" value="3500">
                    </div>
                    <div class="slider-inputs">
                        <div class="slider-input-group">
                            <label class="slider-input-label">Min</label>
                            <input type="number" id="priceMinInput" min="500" max="3500" value="500" step="100">
                        </div>
                        <div class="slider-input-group">
                            <label class="slider-input-label">Max</label>
                            <input type="number" id="priceMaxInput" min="500" max="3500" value="3500" step="100">
                        </div>
                    </div>
