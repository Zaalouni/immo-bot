    <script>
        // ═══════════════════════════════════════════════════════════════════════
        // CONFIGURATION & STATE
        // ═══════════════════════════════════════════════════════════════════════

        // Gares ferroviaires Luxembourg (latitude, longitude)
        const TRAIN_STATIONS = {
            'Luxembourg': { lat: 49.6016, lng: 6.1319 },
            'Esch-sur-Alzette': { lat: 49.5347, lng: 5.9779 },
            'Differdange': { lat: 49.5414, lng: 5.8951 },
            'Dudelange': { lat: 49.4925, lng: 5.9586 },
            'Belfort': { lat: 49.6083, lng: 5.9050 },
            'Pétange': { lat: 49.5547, lng: 5.8622 },
            'Wiltz': { lat: 49.9519, lng: 6.0422 },
            'Diekirch': { lat: 49.8678, lng: 6.2622 },
            'Ettelbruck': { lat: 49.8564, lng: 6.1061 }
        };

        // Configuration constants
        const CONFIG = {
            TRAIN_DISTANCE_THRESHOLD: 10, // km
            DEFAULT_ROOMS_MAX: 5,
            DEFAULT_SURFACE_MIN: 30,
            DEFAULT_SURFACE_MAX: 500,
            DEFAULT_PRICE_MIN: 500,
            DEFAULT_PRICE_MAX: 3500,
            MAP_DEFAULT_ZOOM: 9,
            MAP_DEFAULT_CENTER: [49.615, 6.129],
            DEBOUNCE_DELAY: 300 // ms
        };

        let filteredListings = [];
        let currentView = 'grid';
        let map = null;
        let mapMarkers = [];
        let filterDebounceTimer = null;

        // ═══════════════════════════════════════════════════════════════════════
        // DARK MODE
        // ═══════════════════════════════════════════════════════════════════════
        const dm = document.getElementById('darkModeToggle');
        const dmFloat = document.getElementById('darkModeToggleFloat');

        function applyDarkMode(light) {
            document.body.classList.toggle('light-mode', light);
            const icon = light ? '🌙' : '☀️';
            dm.textContent = icon;
            if (dmFloat) dmFloat.textContent = icon;
            localStorage.setItem('darkMode', light);
        }

        dm.addEventListener('click', () => {
            applyDarkMode(!document.body.classList.contains('light-mode'));
            if (map) map.invalidateSize();
        });

        if (dmFloat) dmFloat.addEventListener('click', () => dm.click());
        applyDarkMode(localStorage.getItem('darkMode') === 'true');

        // ═══════════════════════════════════════════════════════════════════════
        // UTILITIES
        // ═══════════════════════════════════════════════════════════════════════

        // HTML entity escaping for XSS prevention
        function escapeHtml(text) {
            if (!text) return '';
            return String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        // Escape URL attributes to prevent injection
        function escapeUrl(url) {
            if (!url || typeof url !== 'string') return '#';
            const trimmed = url.trim().toLowerCase();
            if (!trimmed.startsWith('http://') && !trimmed.startsWith('https://')) return '#';
            return url.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        }

        function formatPrice(price) {
            return parseInt(price || 0).toLocaleString('fr-FR');
        }

        function getDaysOld(dateStr) {
            if (!dateStr) return 999;
            try {
                const d = new Date(dateStr);
                const now = new Date();
                return Math.floor((now - d) / (1000 * 60 * 60 * 24));
            } catch (e) {
                console.warn('Invalid date:', dateStr);
                return 999;
            }
        }

        // Calculate geodesic distance between coordinates using simplified Haversine formula
        function getClosestTrainDistance(lat, lng) {
            if (!lat || !lng || typeof lat !== 'number' || typeof lng !== 'number') return Infinity;
            if (!Number.isFinite(lat) || !Number.isFinite(lng)) return Infinity;

            let minDist = Infinity;
            for (const station of Object.values(TRAIN_STATIONS)) {
                // Simplified Haversine: assumes small angles, approximates Earth radius
                const dist = Math.hypot(
                    (lat - station.lat) * 111,
                    (lng - station.lng) * 111 * Math.cos(lat * Math.PI / 180)
                );
                minDist = Math.min(minDist, dist);
            }
            return minDist;
        }

        // ═══════════════════════════════════════════════════════════════════════
        // INIT FILTERS
        // ═══════════════════════════════════════════════════════════════════════

        // Find closest train station for a city (cached for performance)
        const trainStationCache = {};
        function getClosestTrainStation(city) {
            if (trainStationCache[city] !== undefined) {
                return trainStationCache[city];
            }

            const cityListing = LISTINGS.find(l => l.city === city && l.latitude && l.longitude && Number.isFinite(l.latitude) && Number.isFinite(l.longitude));
            if (!cityListing) {
                trainStationCache[city] = null;
                return null;
            }

            let closest = null;
            let minDist = Infinity;

            for (const [stationName, station] of Object.entries(TRAIN_STATIONS)) {
                const dist = Math.hypot(
                    (cityListing.latitude - station.lat) * 111,
                    (cityListing.longitude - station.lng) * 111 * Math.cos(cityListing.latitude * Math.PI / 180)
                );
                if (dist < minDist) {
                    minDist = dist;
                    closest = { name: stationName, dist: dist };
                }
            }

            trainStationCache[city] = closest;
            return closest;
        }

        function initFilters() {
            if (!LISTINGS || LISTINGS.length === 0) return;

            // Cities
            const cities = [...new Set(LISTINGS.map(l => l.city).filter(Boolean))].sort();
            const cityCounts = {};
            LISTINGS.forEach(l => {
                if (l.city) cityCounts[l.city] = (cityCounts[l.city] || 0) + 1;
            });

            // Group cities by train station
            const citiesByStation = {};
            const citiesNoStation = [];

            cities.forEach(city => {
                const closest = getClosestTrainStation(city);
                if (closest && closest.dist <= CONFIG.TRAIN_DISTANCE_THRESHOLD) {
                    if (!citiesByStation[closest.name]) {
                        citiesByStation[closest.name] = [];
                    }
                    citiesByStation[closest.name].push({ city, dist: closest.dist });
                } else {
                    citiesNoStation.push(city);
                }
            });

            const cityFilter = document.getElementById('cityFilter');

            // Add cities grouped by train station
            Object.keys(citiesByStation).sort().forEach(stationName => {
                const stationDiv = document.createElement('div');
                stationDiv.style.marginBottom = '0.75rem';
                stationDiv.style.paddingBottom = '0.75rem';
                stationDiv.style.borderBottom = '1px solid var(--border)';

                const stationLabel = document.createElement('div');
                stationLabel.style.fontSize = '0.65rem';
                stationLabel.style.fontWeight = '700';
                stationLabel.style.color = 'var(--gold)';
                stationLabel.style.textTransform = 'uppercase';
                stationLabel.style.letterSpacing = '0.05em';
                stationLabel.style.marginBottom = '0.5rem';
                stationLabel.textContent = `🚂 ${stationName}`;
                stationDiv.appendChild(stationLabel);

                citiesByStation[stationName].sort((a, b) => a.dist - b.dist).forEach(({ city, dist }) => {
                    const div = document.createElement('div');
                    div.className = 'filter-option';
                    const cityEsc = escapeHtml(city);
                    div.innerHTML = `
                        <input type="checkbox" id="city-${cityEsc}" value="${cityEsc}" data-filter="city">
                        <label for="city-${cityEsc}">
                            <span>${cityEsc}</span>
                            <span class="filter-count" title="Distance à la gare">${cityCounts[city]} (${dist.toFixed(1)}km)</span>
                        </label>
                    `;
                    stationDiv.appendChild(div);
                });

                cityFilter.appendChild(stationDiv);
            });

            // Add other cities (no nearby train station)
            if (citiesNoStation.length > 0) {
                const otherDiv = document.createElement('div');
                otherDiv.style.marginTop = '0.75rem';

                const otherLabel = document.createElement('div');
                otherLabel.style.fontSize = '0.65rem';
                otherLabel.style.fontWeight = '700';
                otherLabel.style.color = 'var(--text-muted)';
                otherLabel.style.textTransform = 'uppercase';
                otherLabel.style.letterSpacing = '0.05em';
                otherLabel.style.marginBottom = '0.5rem';
                otherLabel.textContent = '📍 Autres Villes';
                otherDiv.appendChild(otherLabel);

                citiesNoStation.forEach(city => {
                    const div = document.createElement('div');
                    div.className = 'filter-option';
                    const cityEsc = escapeHtml(city);
                    div.innerHTML = `
                        <input type="checkbox" id="city-${cityEsc}" value="${cityEsc}" data-filter="city">
                        <label for="city-${cityEsc}">
                            <span>${cityEsc}</span>
                            <span class="filter-count">(${cityCounts[city]})</span>
                        </label>
                    `;
                    otherDiv.appendChild(div);
                });

                cityFilter.appendChild(otherDiv);
            }

            // Type de bien (détecté depuis titles)
            const types = new Set();
            LISTINGS.forEach(l => {
                if (l.title.toLowerCase().includes('maison')) types.add('Maison');
                if (l.title.toLowerCase().includes('appartement')) types.add('Appartement');
                if (l.title.toLowerCase().includes('studio')) types.add('Studio');
                if (l.title.toLowerCase().includes('commerce')) types.add('Commerce');
            });
            if (types.size === 0) types.add('Appartement');

            const typeFilter = document.getElementById('typeFilter');
            Array.from(types).sort().forEach(type => {
                const div = document.createElement('div');
                div.className = 'filter-option';
                const typeEsc = escapeHtml(type);
                div.innerHTML = `
                    <input type="radio" name="type" id="type-${typeEsc}" value="${typeEsc}" data-filter="type">
                    <label for="type-${typeEsc}">${typeEsc}</label>
                `;
                typeFilter.appendChild(div);
            });

            // Sites
            const sites = [...new Set(LISTINGS.map(l => l.site).filter(Boolean))].sort();
            const siteCounts = {};
            LISTINGS.forEach(l => {
                if (l.site) siteCounts[l.site] = (siteCounts[l.site] || 0) + 1;
            });

            const siteFilter = document.getElementById('siteFilter');
            sites.forEach(site => {
                const div = document.createElement('div');
                div.className = 'filter-option';
                const siteEsc = escapeHtml(site);
                div.innerHTML = `
                    <input type="checkbox" id="site-${siteEsc}" value="${siteEsc}" data-filter="site">
                    <label for="site-${siteEsc}">
                        <span>${siteEsc}</span>
                        <span class="filter-count">(${siteCounts[site]})</span>
                    </label>
                `;
                siteFilter.appendChild(div);
            });
        }

        // ═══════════════════════════════════════════════════════════════════════
        // FILTER & DISPLAY
        // ═══════════════════════════════════════════════════════════════════════

        function applyFilters() {
            if (!LISTINGS) return;

            filteredListings = LISTINGS.filter(listing => {
                // Cities
                const cities = Array.from(document.querySelectorAll('input[data-filter="city"]:checked')).map(el => el.value);
                if (cities.length > 0 && !cities.includes(listing.city)) return false;

                // Type
                const typeSelected = document.querySelector('input[name="type"]:checked')?.value;
                if (typeSelected) {
                    const listingType = listing.title.toLowerCase();
                    if (typeSelected === 'Maison' && !listingType.includes('maison')) return false;
                    if (typeSelected === 'Appartement' && !listingType.includes('appartement')) return false;
                    if (typeSelected === 'Studio' && !listingType.includes('studio')) return false;
                    if (typeSelected === 'Commerce' && !listingType.includes('commerce')) return false;
                }

                // Chambres
                const roomsMin = parseInt(document.getElementById('roomsMin').value);
                const roomsMax = parseInt(document.getElementById('roomsMax').value);
                if (listing.rooms < roomsMin || listing.rooms > roomsMax) return false;

                // Surface (surface=0 = inconnue → ne pas filtrer)
                const surfaceMin = parseInt(document.getElementById('surfaceMin').value);
                const surfaceMax = parseInt(document.getElementById('surfaceMax').value);
                if (listing.surface > 0 && (listing.surface < surfaceMin || listing.surface > surfaceMax)) return false;

                // Prix
                const priceMin = parseInt(document.getElementById('priceMin').value);
                const priceMax = parseInt(document.getElementById('priceMax').value);
                if (listing.price < priceMin || listing.price > priceMax) return false;

                // Période
                const period = document.querySelector('input[name="period"]:checked')?.value;
                if (period !== 'all') {
                    const daysOld = getDaysOld(listing.created_at);
                    if (daysOld > parseInt(period)) return false;
                }

                // Train
                const trainDist = document.querySelector('input[name="train"]:checked')?.value;
                if (trainDist) {
                    const dist = getClosestTrainDistance(listing.latitude, listing.longitude);
                    if (dist > parseFloat(trainDist)) return false;
                }

                // Sites
                const sites = Array.from(document.querySelectorAll('input[data-filter="site"]:checked')).map(el => el.value);
                if (sites.length > 0 && !sites.includes(listing.site)) return false;

                // GPS
                const gpsOnly = document.getElementById('gpsOnly').checked;
                if (gpsOnly && (!listing.latitude || !listing.longitude)) return false;

                return true;
            });

            // Update count
            document.getElementById('countNumber').textContent = filteredListings.length.toLocaleString();

            // Render current view
            if (currentView === 'grid') renderGrid();
            else if (currentView === 'table') renderTable();
            else if (currentView === 'map') renderMap();
        }

        function renderGrid() {
            const grid = document.getElementById('resultsGrid');
            if (filteredListings.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state" style="grid-column: 1/-1;">
                        <div class="empty-state-icon">🔍</div>
                        <div class="empty-state-text">Aucune annonce ne correspond à vos critères</div>
                    </div>
                `;
                return;
            }

            grid.innerHTML = filteredListings.map((l) => {
                const title = escapeHtml(l.title || '').substring(0, 60);
                const city = escapeHtml(l.city || '—');
                const imgSrc = l.local_image
                    ? `<img src="${escapeUrl(l.local_image)}" alt="${title}">`
                    : '📷';
                const url = escapeUrl(l.url || '#');
                const listingId = escapeHtml(l.listing_id || '');

                return `
                <div class="listing-card">
                    <div class="listing-image">
                        ${imgSrc}
                    </div>
                    <div class="listing-content">
                        <div class="listing-price">${formatPrice(l.price)}€</div>
                        <div class="listing-city">${city}</div>
                        <div class="listing-meta">
                            ${l.rooms > 0 ? `<span class="listing-meta-item">🛏️ ${l.rooms}ch</span>` : ''}
                            ${l.surface > 0 ? `<span class="listing-meta-item">📏 ${l.surface}m²</span>` : ''}
                        </div>
                        <div class="listing-actions">
                            <a href="${url}" target="_blank" rel="noopener" class="btn-view">Voir</a>
                            <button class="btn-favorite" data-id="${listingId}" title="Ajouter aux favoris">⭐</button>
                        </div>
                    </div>
                </div>
            `;}).join('');

            // Attach favorite listeners
            grid.querySelectorAll('.btn-favorite').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    btn.classList.toggle('active');
                    saveFavorite(btn.dataset.id, btn.classList.contains('active'));
                });
            });

            // Restore favorites visual state after re-render
            loadFavorites();
        }

        function renderTable() {
            const tbody = document.getElementById('resultsTableBody');
            if (filteredListings.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" style="text-align: center; padding: 2rem; color: var(--text-muted);">Aucune annonce</td></tr>`;
                return;
            }

            tbody.innerHTML = filteredListings.map(l => {
                const url = escapeUrl(l.url || '#');
                const rawTitle = l.title || '';
                const title = escapeHtml(rawTitle).substring(0, 40);
                const titleSuffix = rawTitle.length > 40 ? '…' : '';
                const city = escapeHtml(l.city || '—');

                return `
                <tr>
                    <td>${formatPrice(l.price)}€</td>
                    <td>${title}${titleSuffix}</td>
                    <td class="td-city">${city}</td>
                    <td>${l.rooms > 0 ? l.rooms : '—'}</td>
                    <td>${l.surface > 0 ? l.surface + 'm²' : '—'}</td>
                    <td>${getDaysOld(l.created_at)}j</td>
                    <td class="td-actions">
                        <a href="${url}" target="_blank" rel="noopener">Voir →</a>
                    </td>
                </tr>
            `;}).join('');
        }

        function renderMap() {
            if (!map) {
                const mapEl = document.getElementById('resultsMap');
                if (!mapEl) {
                    console.warn('Map element not found');
                    return;
                }
                map = L.map(mapEl).setView(CONFIG.MAP_DEFAULT_CENTER, CONFIG.MAP_DEFAULT_ZOOM);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '© OpenStreetMap'
                }).addTo(map);
                setTimeout(() => map.invalidateSize(), 100);
            }

            // Clear old markers
            mapMarkers.forEach(m => map.removeLayer(m));
            mapMarkers = [];

            if (filteredListings.length === 0) {
                map.invalidateSize();
                return;
            }

            // Add markers for valid listings with coordinates
            filteredListings.forEach(l => {
                if (l.latitude && l.longitude && Number.isFinite(l.latitude) && Number.isFinite(l.longitude)) {
                    const city = escapeHtml(l.city || '');
                    const url = escapeUrl(l.url || '#');
                    const popup = `<strong>${formatPrice(l.price)}€</strong><br/>${city}<br/><a href="${url}" target="_blank" rel="noopener">Voir</a>`;

                    const marker = L.circleMarker([l.latitude, l.longitude], {
                        radius: 6,
                        fillColor: '#C9A265',
                        color: '#C9A265',
                        weight: 2,
                        opacity: 0.8,
                        fillOpacity: 0.6
                    }).bindPopup(popup);

                    marker.addTo(map);
                    mapMarkers.push(marker);
                }
            });

            // Fit bounds with error handling
            if (mapMarkers.length > 0) {
                try {
                    const group = new L.featureGroup(mapMarkers);
                    const bounds = group.getBounds();
                    if (bounds.isValid()) {
                        map.fitBounds(bounds.pad(0.1));
                    }
                } catch (e) {
                    console.warn('Could not fit map bounds:', e);
                }
            }

            map.invalidateSize();
        }

        // ═══════════════════════════════════════════════════════════════════════
        // EVENT LISTENERS
        // ═══════════════════════════════════════════════════════════════════════

        // Debounced filter application to improve performance
        function triggerFilterApply() {
            clearTimeout(filterDebounceTimer);
            filterDebounceTimer = setTimeout(() => {
                applyFilters();
            }, CONFIG.DEBOUNCE_DELAY);
        }

        // Attach event listeners with delegation for dynamic filter elements
        function attachFilterListeners() {
            const filtersSidebar = document.getElementById('filtersSidebar');

            // Delegate events on sidebar for checkbox and radio changes
            filtersSidebar.addEventListener('change', (e) => {
                if (e.target.type === 'checkbox' || e.target.type === 'radio') {
                    triggerFilterApply();
                }
                // Handle number inputs (sync to slider and apply filters)
                if (e.target.type === 'number') {
                    const sliderId = e.target.id.replace('Input', '').replace('Min', 'Min').replace('Max', 'Max');
                    const slider = document.getElementById(sliderId);
                    if (slider) {
                        let val = parseInt(e.target.value) || 0;
                        // Prevent min > max and vice versa
                        const isMin = sliderId.includes('Min');
                        const isMax = sliderId.includes('Max');

                        if (isMin) {
                            const maxInputId = sliderId.replace('Min', 'Max') + 'Input';
                            const maxInput = document.getElementById(maxInputId);
                            if (maxInput) {
                                const maxVal = parseInt(maxInput.value);
                                if (val > maxVal) maxInput.value = val;
                            }
                        } else if (isMax) {
                            const minInputId = sliderId.replace('Max', 'Min') + 'Input';
                            const minInput = document.getElementById(minInputId);
                            if (minInput) {
                                const minVal = parseInt(minInput.value);
                                if (val < minVal) minInput.value = val;
                            }
                        }
                        slider.value = val;
                    }
                    triggerFilterApply();
                }
            });

            // Delegate events for range sliders (input event for live feedback)
            filtersSidebar.addEventListener('input', (e) => {
                if (e.target.type === 'range') {
                    const inputId = e.target.id.replace('Min', 'MinInput').replace('Max', 'MaxInput');
                    const inputElem = document.getElementById(inputId);
                    if (inputElem) inputElem.value = e.target.value;

                    // Prevent min > max by syncing slider values
                    const isMin = e.target.id.includes('Min');
                    if (isMin) {
                        const maxSliderId = e.target.id.replace('Min', 'Max');
                        const maxSlider = document.getElementById(maxSliderId);
                        if (maxSlider && parseInt(e.target.value) > parseInt(maxSlider.value)) {
                            maxSlider.value = e.target.value;
                            const maxInputId = maxSliderId + 'Input';
                            const maxInput = document.getElementById(maxInputId);
                            if (maxInput) maxInput.value = e.target.value;
                        }
                    } else {
                        const minSliderId = e.target.id.replace('Max', 'Min');
                        const minSlider = document.getElementById(minSliderId);
                        if (minSlider && parseInt(e.target.value) < parseInt(minSlider.value)) {
                            minSlider.value = e.target.value;
                            const minInputId = minSliderId + 'Input';
                            const minInput = document.getElementById(minInputId);
                            if (minInput) minInput.value = e.target.value;
                        }
                    }
                    triggerFilterApply();
                }
            });
        }

        // Setup view switcher and reset button
        function setupUIControls() {
            // View switcher
            document.querySelectorAll('.view-button').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.view-button').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    currentView = e.target.dataset.view;

                    document.querySelectorAll('.results-grid, .results-table, .results-map').forEach(el => {
                        el.classList.remove('active');
                    });

                    if (currentView === 'grid') {
                        document.getElementById('resultsGrid').classList.add('active');
                        renderGrid();
                    } else if (currentView === 'table') {
                        document.getElementById('resultsTable').classList.add('active');
                        renderTable();
                    } else if (currentView === 'map') {
                        document.getElementById('resultsMap').classList.add('active');
                        renderMap();
                    }
                });
            });

            // Reset button
            const resetBtn = document.getElementById('resetBtn');
            if (resetBtn) {
                resetBtn.addEventListener('click', () => {
                    document.querySelectorAll('input[type="checkbox"]').forEach(el => el.checked = false);
                    document.querySelectorAll('input[type="radio"]').forEach(el => el.checked = el.id.endsWith('-all'));

                    // Reset to default values from CONFIG
                    document.getElementById('roomsMin').value = 0;
                    document.getElementById('roomsMax').value = CONFIG.DEFAULT_ROOMS_MAX;
                    document.getElementById('roomsMinInput').value = 0;
                    document.getElementById('roomsMaxInput').value = CONFIG.DEFAULT_ROOMS_MAX;

                    document.getElementById('surfaceMin').value = CONFIG.DEFAULT_SURFACE_MIN;
                    document.getElementById('surfaceMax').value = CONFIG.DEFAULT_SURFACE_MAX;
                    document.getElementById('surfaceMinInput').value = CONFIG.DEFAULT_SURFACE_MIN;
                    document.getElementById('surfaceMaxInput').value = CONFIG.DEFAULT_SURFACE_MAX;

                    document.getElementById('priceMin').value = CONFIG.DEFAULT_PRICE_MIN;
                    document.getElementById('priceMax').value = CONFIG.DEFAULT_PRICE_MAX;
                    document.getElementById('priceMinInput').value = CONFIG.DEFAULT_PRICE_MIN;
                    document.getElementById('priceMaxInput').value = CONFIG.DEFAULT_PRICE_MAX;

                    applyFilters();
                });
            }
        }

        // Favorites
        function saveFavorite(id, isFav) {
            let favs = JSON.parse(localStorage.getItem('favorites') || '[]');
            if (isFav) {
                if (!favs.includes(id)) favs.push(id);
            } else {
                favs = favs.filter(f => f !== id);
            }
            localStorage.setItem('favorites', JSON.stringify(favs));
        }

        function loadFavorites() {
            const favs = JSON.parse(localStorage.getItem('favorites') || '[]');
            document.querySelectorAll('.btn-favorite').forEach(btn => {
                if (favs.includes(btn.dataset.id)) {
                    btn.classList.add('active');
                }
            });
        }

        // Mobile filter sidebar toggle
        const mobileFilterToggle = document.getElementById('mobileFilterToggle');
        const filtersSidebar = document.getElementById('filtersSidebar');

        if (mobileFilterToggle && filtersSidebar) {
            mobileFilterToggle.addEventListener('click', () => {
                filtersSidebar.classList.toggle('mobile-open');
                // Update button visual state
                mobileFilterToggle.style.display = window.innerWidth > 768 ? 'none' : 'block';
            });

            // Close sidebar when clicking a filter option
            filtersSidebar.addEventListener('change', () => {
                if (window.innerWidth <= 768) {
                    filtersSidebar.classList.remove('mobile-open');
                }
            });

            // Handle window resize
            window.addEventListener('resize', () => {
                if (window.innerWidth > 768) {
                    filtersSidebar.classList.remove('mobile-open');
                }
            });
        }

        // ═══════════════════════════════════════════════════════════════════════
        // INIT
        // ═══════════════════════════════════════════════════════════════════════

        window.addEventListener('DOMContentLoaded', () => {
            if (!LISTINGS || !Array.isArray(LISTINGS) || LISTINGS.length === 0) {
                console.error('No listings data available');
                document.getElementById('resultsGrid').innerHTML = `
                    <div class="empty-state" style="grid-column: 1/-1;">
                        <div class="empty-state-icon">⚠️</div>
                        <div class="empty-state-text">Impossible de charger les annonces</div>
                    </div>
                `;
                return;
            }
            initFilters();

            // Setup all event listeners AFTER initFilters creates dynamic elements
            attachFilterListeners();
            setupUIControls();

            applyFilters();
            loadFavorites();

            // Hide mobile toggle on desktop
            if (mobileFilterToggle) {
                mobileFilterToggle.style.display = window.innerWidth > 768 ? 'none' : 'block';
            }
        });

        // Service Worker registration with error handling
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('sw.js').catch(err => {
                console.debug('Service Worker registration failed:', err);
            });
        }
    </script>
    <script src="nav-menu.js" defer></script>


